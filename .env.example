# Copy to .env and fill values. NEVER commit .env

# --- API ---
API_HOST=0.0.0.0
API_PORT=3001
SESSION_SECRET=replace-with-long-random-string

# Admin login (v1: single admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Ingest: stub | prim | navitia
INGEST_PROVIDER=stub

# PRIM (Île-de-France Mobilités) — see README
PRIM_API_KEY=

# Navitia / SNCF open data — see README
NAVITIA_TOKEN=

# Email SMTP custom
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Microsoft Teams Incoming Webhook
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Copy to .env and fill values. NEVER commit .env

# --- API ---
API_HOST=0.0.0.0
API_PORT=3001
SESSION_SECRET=replace-with-long-random-string
SESSION_TTL_HOURS=12
# true if the web UI is served over HTTPS (port 443)
COOKIE_SECURE=true

# Admin login (v1: single admin) — hashed in Postgres on first boot
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# Set true once to re-hash ADMIN_PASSWORD into DB, then set back to false
ADMIN_PASSWORD_SYNC=false

# Login rate limit
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_MS=900000

# PostgreSQL
DATABASE_URL=postgres://sncf:sncf@127.0.0.1:5432/sncf_alerts

# Ingest: stub | prim | navitia
INGEST_PROVIDER=stub
INGEST_INTERVAL_MS=60000

# PRIM (Île-de-France Mobilités) — see README
PRIM_API_KEY=

# Navitia / SNCF open data — see README
NAVITIA_TOKEN=

# Email SMTP custom
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Microsoft Teams Incoming Webhook
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=
